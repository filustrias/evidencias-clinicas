---
/**
 * Painel "Aa" — três radiogroups (tema, tamanho, fonte).
 * Lógica de eventos vive em `src/scripts/theme-controls.ts` e é
 * importada uma única vez pelo BaseLayout. Aqui é só a estrutura.
 */
---
<div class="relative">
  <button
    id="aa-trigger"
    type="button"
    aria-label="Aparência"
    aria-expanded="false"
    aria-controls="aa-panel"
    class="inline-flex items-center justify-center h-9 w-9 rounded-md text-text-primary border border-border-subtle hover:bg-elevated transition-colors"
  >
    <span aria-hidden="true" class="text-base font-medium">Aa</span>
  </button>

  <div
    id="aa-panel"
    role="dialog"
    aria-label="Aparência"
    hidden
    class="absolute right-0 top-[calc(100%+8px)] z-50 w-72 rounded-lg border border-border-default bg-canvas p-4 shadow-[0_8px_24px_rgba(0,0,0,0.08)] dark:shadow-[0_8px_24px_rgba(0,0,0,0.4)]"
  >
    {/* ---------- Tema ---------- */}
    <section class="mb-4">
      <h3 class="text-xs font-medium uppercase tracking-wide text-text-muted mb-2">
        Aparência
      </h3>
      <div role="radiogroup" aria-label="Tema" data-aa-radiogroup class="grid grid-cols-3 gap-1 rounded-md bg-elevated p-1">
        <button
          role="radio"
          type="button"
          data-theme="auto"
          aria-checked="true"
          tabindex="0"
          class="aa-radio"
        >Auto</button>
        <button
          role="radio"
          type="button"
          data-theme="light"
          aria-checked="false"
          tabindex="-1"
          class="aa-radio"
        >Claro</button>
        <button
          role="radio"
          type="button"
          data-theme="dark"
          aria-checked="false"
          tabindex="-1"
          class="aa-radio"
        >Escuro</button>
      </div>
    </section>

    {/* ---------- Tamanho ---------- */}
    <section class="mb-4">
      <h3 class="text-xs font-medium uppercase tracking-wide text-text-muted mb-2">
        Tamanho do texto
      </h3>
      <div role="radiogroup" aria-label="Tamanho da fonte" data-aa-radiogroup class="grid grid-cols-3 gap-1 rounded-md bg-elevated p-1">
        <button
          role="radio"
          type="button"
          data-size="small"
          aria-checked="false"
          tabindex="-1"
          class="aa-radio"
        ><span class="text-xs">A−</span></button>
        <button
          role="radio"
          type="button"
          data-size="default"
          aria-checked="true"
          tabindex="0"
          class="aa-radio"
        ><span class="text-sm">A</span></button>
        <button
          role="radio"
          type="button"
          data-size="large"
          aria-checked="false"
          tabindex="-1"
          class="aa-radio"
        ><span class="text-base">A+</span></button>
      </div>
    </section>

    {/* ---------- Estilo da fonte ---------- */}
    <section>
      <h3 class="text-xs font-medium uppercase tracking-wide text-text-muted mb-2">
        Estilo da fonte
      </h3>
      <div role="radiogroup" aria-label="Estilo da fonte" data-aa-radiogroup class="grid grid-cols-2 gap-1 rounded-md bg-elevated p-1">
        <button
          role="radio"
          type="button"
          data-font="sans"
          aria-checked="true"
          tabindex="0"
          class="aa-radio"
        >Sem serifa</button>
        <button
          role="radio"
          type="button"
          data-font="serif"
          aria-checked="false"
          tabindex="-1"
          class="aa-radio font-serif"
        >Com serifa</button>
      </div>
    </section>
  </div>
</div>

<style>
  .aa-radio {
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-sm);
    font-size: 0.875rem;
    line-height: 1.25;
    background: transparent;
    color: var(--color-text-secondary);
    transition: background-color 150ms ease-out, color 150ms ease-out;
    cursor: pointer;
  }
  .aa-radio:hover {
    color: var(--color-text-primary);
  }
  .aa-radio[aria-checked='true'] {
    background: var(--color-bg-canvas);
    color: var(--color-text-primary);
    font-weight: 500;
    box-shadow: 0 0 0 1px var(--color-border-subtle);
  }
</style>
