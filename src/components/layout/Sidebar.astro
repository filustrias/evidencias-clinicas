---
import { getSectionNav, withBase, stripBase } from '@/data/navigation';

export interface Props {
  section: string;
  currentPath: string;
}

const { section, currentPath } = Astro.props;
const base = import.meta.env.BASE_URL;
const items = getSectionNav(section);
const normalizedCurrent = stripBase(currentPath, base);
---
{items && (
  <nav aria-label="Páginas desta seção" class="text-sm">
    <ul class="space-y-0.5">
      {items.map((item) => {
        const active = normalizedCurrent === item.href;
        return (
          <li>
            <a
              href={withBase(item.href, base)}
              class:list={[
                'relative block py-2 px-3 rounded-md transition-colors',
                active
                  ? 'text-accent font-medium bg-accent-soft-bg'
                  : 'text-text-secondary hover:text-text-primary hover:bg-elevated',
              ]}
              aria-current={active ? 'page' : undefined}
            >
              {active && (
                <span
                  aria-hidden="true"
                  class="absolute left-0 top-1.5 bottom-1.5 w-[2px] bg-accent rounded-full"
                ></span>
              )}
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
)}
