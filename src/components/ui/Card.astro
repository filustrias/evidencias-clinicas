---
export interface Props {
  href?: string;
  class?: string;
  padded?: boolean;
}

const { href, class: className = '', padded = true } = Astro.props;
const baseClasses = 'block rounded-lg border border-border-subtle bg-surface transition-colors';
const interactiveClasses = href ? 'hover:border-border-default hover:bg-elevated' : '';
const paddingClasses = padded ? 'p-5' : '';
const classList = `${baseClasses} ${interactiveClasses} ${paddingClasses} ${className}`.trim();
---
{href ? (
  <a href={href} class={classList}><slot /></a>
) : (
  <div class={classList}><slot /></div>
)}
