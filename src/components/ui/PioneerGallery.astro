---
/**
 * Galeria de pioneiros — três retratos lado a lado em desktop, empilhados em mobile.
 * Cada item: foto retrato + nome em destaque + legenda biográfica.
 * Aspect-ratio fixo para todas as fotos (3:4 retrato) para que diferentes resoluções
 * de origem não causem layout shift entre cards.
 */
export interface Pioneer {
  name: string;
  image: string;
  width: number;
  height: number;
  caption: string;
}

export interface Props {
  pioneers: Pioneer[];
}

const { pioneers } = Astro.props;
---
<div class="not-prose pioneer-gallery">
  {pioneers.map((p) => (
    <figure class="pioneer-card">
      <div class="pioneer-frame">
        <img
          src={p.image}
          alt={`Retrato de ${p.name}`}
          width={p.width}
          height={p.height}
          loading="lazy"
          decoding="async"
        />
      </div>
      <figcaption>
        <p class="pioneer-name">{p.name}</p>
        <p class="pioneer-caption">{p.caption}</p>
      </figcaption>
    </figure>
  ))}
</div>

<style>
  .pioneer-gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin: 2rem 0 2.5rem;
  }
  @media (min-width: 640px) {
    .pioneer-gallery {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  .pioneer-card {
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .pioneer-frame {
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-subtle);
  }

  .pioneer-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .pioneer-name {
    margin: 0.875rem 0 0.25rem;
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-primary);
    line-height: 1.4;
  }

  .pioneer-caption {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--color-text-secondary);
  }
</style>
