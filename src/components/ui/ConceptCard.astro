---
export interface Props {
  href: string;
  title: string;
  description?: string;
  badge?: string;
}

const { href, title, description, badge } = Astro.props;
---
<a
  href={href}
  class="group block rounded-lg border border-border-subtle bg-surface p-5 transition-all hover:border-accent hover:shadow-[0_2px_8px_rgba(0,0,0,0.04)]"
>
  {badge && (
    <span class="inline-flex items-center rounded-full bg-accent-soft-bg px-2 py-0.5 text-xs font-medium text-accent-soft-text mb-2">
      {badge}
    </span>
  )}
  <h3 class="text-lg font-medium text-text-primary group-hover:text-accent transition-colors">
    {title}
  </h3>
  {description && (
    <p class="mt-2 text-sm text-text-secondary leading-relaxed">{description}</p>
  )}
  <span class="mt-3 inline-flex items-center text-sm text-accent gap-1 group-hover:gap-2 transition-all">
    Ler
    <svg viewBox="0 0 16 16" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
      <path d="M6 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </span>
</a>
