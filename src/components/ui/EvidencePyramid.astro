---
/**
 * Pirâmide de evidências — 6 camadas empilhadas, da mais frágil (base, translúcida)
 * à mais robusta (topo, sólida). Cada camada é um link clicável para a página de
 * desenhos de estudo, com âncora ao tipo correspondente.
 *
 * Implementação: CSS clip-path para o trapezoide de cada camada (sem SVG complexo).
 * Cada linha da pirâmide é um <a> contendo a forma à esquerda e o rótulo à direita,
 * formando uma única área clicável por camada.
 *
 * Em mobile (≤ 640px) a pirâmide visual some e dá lugar a uma lista numerada
 * vertical, mantendo a mesma ordem (topo → base) e a gradação de saturação no
 * indicador lateral de cada item.
 *
 * Reutilizável: também será usada na página /conceitos/piramide-evidencias.
 */
import { withBase } from '@/data/navigation';

export interface Props {
  /**
   * Caminho base para os links das camadas. Default: /conceitos/desenhos-de-estudo/.
   * Permite reapontar para outra página (ex.: /conceitos/piramide-evidencias/) sem
   * redefinir todas as camadas.
   */
  basePath?: string;
}

const { basePath = '/conceitos/desenhos-de-estudo/' } = Astro.props;
const base = import.meta.env.BASE_URL;

// Camadas listadas do topo (mais robusto) para a base (mais frágil), que é
// a ordem visual e também a recomendada pelo brief para o fallback mobile.
const layers = [
  {
    num: 6,
    label: 'Revisões sistemáticas e meta-análises',
    short: 'Síntese crítica de múltiplos estudos',
    anchor: '#revisoes-sistematicas',
    strength: 100,
  },
  {
    num: 5,
    label: 'Ensaios clínicos randomizados (ECR)',
    short: 'Padrão-ouro para eficácia de intervenções',
    anchor: '#ensaios-clinicos-randomizados',
    strength: 82,
  },
  {
    num: 4,
    label: 'Coorte e caso-controle',
    short: 'Observacionais, estabelecem associações',
    anchor: '#coorte-caso-controle',
    strength: 65,
  },
  {
    num: 3,
    label: 'Estudos transversais',
    short: 'Fotografia da população num momento',
    anchor: '#estudos-transversais',
    strength: 48,
  },
  {
    num: 2,
    label: 'Relatos e séries de casos',
    short: 'Descritivos, sinalizam fenômenos novos',
    anchor: '#relatos-e-series-de-casos',
    strength: 32,
  },
  {
    num: 1,
    label: 'Opinião de especialistas, in vitro, animais',
    short: 'Geram hipóteses, não sustentam decisões',
    anchor: '#opiniao-de-especialistas',
    strength: 18,
  },
];

const N = layers.length;

const rows = layers.map((l, i) => ({
  ...l,
  // Half-width das bordas top/bottom da camada, em % de uma metade de container.
  // Ex.: para i=0 (apex), top=0, bottom=50/N ≈ 8.33% (camada bem fina)
  //      para i=N-1 (base), top=(N-1)*50/N ≈ 41.67%, bottom=50% (largura cheia)
  topHalf: (i * 50) / N,
  bottomHalf: ((i + 1) * 50) / N,
  href: withBase(`${basePath}${l.anchor}`, base),
}));
---
<nav class="not-prose evidence-pyramid" aria-label="Pirâmide de evidências">
  <ol class="ep-rows">
    {rows.map((r) => (
      <li class="ep-row" style={`--strength:${r.strength}%;--top-half:${r.topHalf}%;--bottom-half:${r.bottomHalf}%;`}>
        <a href={r.href} class="ep-link" aria-label={`Nível ${r.num}: ${r.label}`}>
          <span class="ep-shape" aria-hidden="true"></span>
          <span class="ep-label">
            <span class="ep-num" aria-hidden="true">{r.num}</span>
            <span class="ep-text">
              <span class="ep-title">{r.label}</span>
              <span class="ep-short">{r.short}</span>
            </span>
          </span>
        </a>
      </li>
    ))}
  </ol>
</nav>

<style>
  .evidence-pyramid {
    margin: 2rem 0 2.5rem;
  }
  .ep-rows {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ep-link {
    display: flex;
    align-items: stretch;
    text-decoration: none;
    color: inherit;
    transition: background-color 150ms ease-out;
  }

  .ep-shape {
    /* Trapezoide preenchido, gerado via clip-path em % do próprio elemento. */
    flex: 0 0 50%;
    min-height: 56px;
    background: color-mix(in srgb, var(--color-accent) var(--strength), var(--color-bg-canvas));
    clip-path: polygon(
      calc(50% - var(--top-half)) 0%,
      calc(50% + var(--top-half)) 0%,
      calc(50% + var(--bottom-half)) 100%,
      calc(50% - var(--bottom-half)) 100%
    );
    transition: filter 150ms ease-out, background-color 150ms ease-out;
  }

  .ep-label {
    flex: 1 1 0;
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.625rem 0 0.625rem 1.25rem;
    border-bottom: 1px dashed var(--color-border-subtle);
  }
  .ep-row:last-child .ep-label {
    border-bottom: 0;
  }

  .ep-num {
    flex: 0 0 auto;
    width: 1.75rem;
    height: 1.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: color-mix(in srgb, var(--color-accent) var(--strength), var(--color-bg-canvas));
    color: var(--color-text-primary);
    font-weight: 500;
    font-size: 0.8125rem;
    font-family: var(--font-mono);
  }

  /* Para camadas saturadas (≥ 50%), texto claro no badge para garantir contraste */
  .ep-row[style*='--strength:100%'] .ep-num,
  .ep-row[style*='--strength:82%'] .ep-num,
  .ep-row[style*='--strength:65%'] .ep-num {
    color: #ffffff;
  }

  .ep-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .ep-title {
    font-weight: 500;
    font-size: 0.9375rem;
    line-height: 1.3;
    color: var(--color-text-primary);
  }
  .ep-short {
    font-size: 0.8125rem;
    line-height: 1.4;
    color: var(--color-text-secondary);
    margin-top: 0.15rem;
  }

  /* ---------- Hover / focus ---------- */
  .ep-link:hover .ep-shape,
  .ep-link:focus-visible .ep-shape {
    filter: brightness(0.95) saturate(1.1);
  }
  :global([data-theme='dark']) .ep-link:hover .ep-shape,
  :global([data-theme='dark']) .ep-link:focus-visible .ep-shape {
    filter: brightness(1.15) saturate(1.1);
  }
  .ep-link:hover .ep-title,
  .ep-link:focus-visible .ep-title {
    color: var(--color-accent);
  }
  .ep-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* ---------- Mobile fallback (≤ 640px) ---------- */
  @media (max-width: 640px) {
    .ep-shape {
      /* Vira uma faixa lateral colorida em vez do trapezoide */
      flex: 0 0 6px;
      clip-path: none;
      min-height: auto;
    }
    .ep-label {
      padding: 0.875rem 0 0.875rem 1rem;
      border-bottom: 1px solid var(--color-border-subtle);
    }
    .ep-link {
      gap: 0;
    }
    .ep-row {
      margin: 0;
    }
  }
</style>
