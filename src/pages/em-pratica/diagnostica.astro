        </tr>
      </thead>
      <tbody>
        <tr>
          <td><a href={withBase('/conceitos/pico/', base)}>PICO</a></td>
          <td>Estrutura da pergunta diagnóstica</td>
        </tr>
        <tr>
          <td><a href={withBase('/conceitos/testes-diagnosticos/', base)}>Sensibilidade, especificidade, VPP, VPN</a></td>
