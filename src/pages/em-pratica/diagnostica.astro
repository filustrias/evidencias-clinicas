        </tr>
        <tr>
          <td><a href={withBase('/calculadoras/testes-diagnosticos/', base)}>Calculadora de testes diagnósticos</a></td>
          <td>Aplicação ao contexto local</td>
        </tr>
        <tr>
          <td><a href={withBase('/conceitos/vieses/', base)}>Vieses</a></td>
          <td>Espectro, verificação, incorporação</td>
        </tr>
        <tr>
          <td><a href={withBase('/conceitos/decisao-compartilhada/', base)}>Decisão compartilhada</a></td>
          <td>Comunicação com a paciente</td>
        </tr>
        <tr>
          <td><a href={withBase('/cinco-as/aplicar/', base)}>Apply</a></td>
