---
import PageLayout from '@layouts/PageLayout.astro';
---
<PageLayout
  title="Referências"
  description="Bibliografia e fontes consultadas para o conteúdo deste site."
>
  <h1 class="text-4xl font-medium mb-3">Referências</h1>
  <p class="text-lg text-text-secondary mb-6">
    Bibliografia, diretrizes e fontes consultadas, organizadas por tema.
  </p>
  <div class="rounded-lg border border-border-subtle bg-surface p-5 text-sm text-text-secondary">
    Em construção. Conteúdo em breve.
  </div>
</PageLayout>
