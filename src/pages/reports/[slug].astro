---
// src/pages/reports/[slug].astro
//
// Gera uma página estática para cada arquivo em src/content/reports/*.yaml.
// URL final: /reports/[slug]

import { getCollection } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import Report from '@components/report/Report.astro';

export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const description = entry.data.clinical_message
  .replace(/<[^>]+>/g, '')
  .replace(/\*\*?/g, '')
  .slice(0, 160);
---

<BaseLayout title={entry.data.title} description={description} section="reports">
  <Report entry={entry} />
</BaseLayout>
