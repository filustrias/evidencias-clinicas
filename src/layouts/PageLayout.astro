---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '@components/layout/Sidebar.astro';
import TableOfContents from '@components/layout/TableOfContents.astro';

export interface Props {
  title: string;
  description?: string;
  /**
   * Identifier of the section the page belongs to.
   * Drives the left sidebar contents. Examples: 'cinco-as', 'conceitos', 'ferramentas',
   * 'calculadoras', 'em-pratica'. Standalone pages (sobre, glossário) pass `undefined`.
   */
  section?: string;
  /** Show the right-hand TOC. Pages opt in explicitly when long enough. */
  showToc?: boolean;
  /** Render in a wide, prose-free layout (e.g., calculadora pages, dashboards). */
  wide?: boolean;
}

const {
  title,
  description,
  section,
  showToc = false,
  wide = false,
} = Astro.props;

const hasSidebar = Boolean(section);
const hasToc = showToc;
---
<BaseLayout title={title} description={description} section={section}>
  <div class="mx-auto max-w-[1280px] px-5 lg:px-12 py-8 lg:py-12">
    <div
      class:list={[
        'grid gap-8 lg:gap-12',
        hasSidebar && hasToc && 'lg:grid-cols-[280px_minmax(0,1fr)_240px]',
        hasSidebar && !hasToc && 'lg:grid-cols-[280px_minmax(0,1fr)]',
        !hasSidebar && hasToc && 'lg:grid-cols-[minmax(0,1fr)_240px]',
        !hasSidebar && !hasToc && 'lg:grid-cols-1',
      ]}
    >
      {hasSidebar && (
        <aside class="hidden lg:block" aria-label="Navegação da seção">
          <div class="sticky top-[80px]">
            <Sidebar section={section!} currentPath={Astro.url.pathname} />
          </div>
        </aside>
      )}

      <article class:list={['min-w-0', !wide && 'lg:max-w-prose']}>
        <slot />
      </article>

      {hasToc && (
        <aside class="hidden lg:block" aria-label="Sumário desta página">
          <div class="sticky top-[80px]">
            <TableOfContents />
          </div>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>
